@model ProductoIndexViewModel
@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Productos</h1>
        <p class="text-muted mb-0">Catálogo de productos con filtros y paginación</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Nuevo producto</a>
</div>


<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label form-label-sm mb-1">Nombre</label>
                <input type="text" name="nombre" value="@Model.NombreFiltro"
                       class="form-control form-control-sm" placeholder="Buscar por nombre" />
            </div>
            <div class="col-md-4">
                <label class="form-label form-label-sm mb-1">Categoría</label>
                <select name="categoriaId" class="form-select form-select-sm"
                        asp-items="Model.Categorias">
                    <option value="">Todas las categorías</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-outline-primary w-100">Filtrar</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary w-100">Limpiar</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">Imagen</th>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th class="text-end">Precio</th>
                    <th class="text-center">IVA%</th>
                    <th class="text-center">Stock</th>
                    <th class="text-center">Activo</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Productos)
            {
                <tr>
                    <td>
                        <img src="@item.ImagenUrl" alt="@item.Nombre"
                             class="rounded" style="width:45px;height:45px;object-fit:cover;"
                             onerror="this.src='/uploads/productos/placeholder.png'" />
                    </td>
                    <td>@item.Nombre</td>
                    <td>@item.Categoria?.Nombre</td>
                    <td class="text-end">@item.Precio.ToString("C")</td>
                    <td class="text-center">@item.ImpuestoPorc%</td>
                    <td class="text-center">@item.Stock</td>
                    <td class="text-center">
                        @if (item.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">Ver</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
                    </td>
                </tr>
            }
            @if (!Model.Productos.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">No se encontraron productos.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (Model.Productos.PageCount > 1)
    {
        <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
            <small class="text-muted">
                Mostrando @Model.Productos.FirstItemOnPage–@Model.Productos.LastItemOnPage
                de @Model.Productos.TotalItemCount productos
            </small>
            @Html.PagedListPager(Model.Productos, page => Url.Action("Index", new
            {
                page,
                nombre     = Model.NombreFiltro,
                categoriaId= Model.CategoriaFiltro
            }), new X.PagedList.Mvc.Core.PagedListRenderOptions
            {
                LiElementClasses      = new[] { "page-item" },
                PageClasses           = new[] { "page-link" },
                UlElementClasses      = new[] { "pagination pagination-sm mb-0" }
            })
        </div>
    }
</div>
